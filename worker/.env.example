# ---- Postgres (Neon) ----
# Use the pooled / connection-string URL from the Neon console.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ---- Cloudflare R2 ----
# Account ID: Cloudflare dashboard -> right sidebar on any page.
R2_ACCOUNT_ID=
# API token: R2 > Manage R2 API Tokens > Create API Token with Object Read+Write
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name (create a bucket in R2 first, e.g. "pointcloud3d").
R2_BUCKET=pointcloud3d

# ---- Worker ----
WORKER_ID=mac-mini-1
WORKER_POLL_INTERVAL=2.0

# ---- Optional: HuggingFace (higher HF Hub rate limits) ----
# HF_TOKEN=
